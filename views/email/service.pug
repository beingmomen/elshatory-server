extends baseEmail

block content
  h2 طلب خدمة جديد
  p تم استلام طلب خدمة جديد من:
  
  table(style="width: 100%; border-collapse: collapse; margin: 20px 0;")
    tr
      td(style="padding: 10px; border: 1px solid #ddd; font-weight: bold;") الاسم:
      td(style="padding: 10px; border: 1px solid #ddd;") #{name}
    tr
      td(style="padding: 10px; border: 1px solid #ddd; font-weight: bold;") البريد الإلكتروني:
      td(style="padding: 10px; border: 1px solid #ddd;") #{email}
    tr
      td(style="padding: 10px; border: 1px solid #ddd; font-weight: bold;") رقم الهاتف:
      td(style="padding: 10px; border: 1px solid #ddd;") #{phone}
    tr
      td(style="padding: 10px; border: 1px solid #ddd; font-weight: bold;") الوصف:
      td(style="padding: 10px; border: 1px solid #ddd;") #{description}